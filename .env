# Appwrite — copy to .env.local and fill with your Appwrite project values.
# Get these from: https://cloud.appwrite.io/console → your project → Settings / Overview.

# Required: Appwrite API endpoint (use your region, e.g. https://cloud.appwrite.io/v1)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1

# Required: Project ID from Appwrite Console
NEXT_PUBLIC_APPWRITE_PROJECT_ID=backing-score

# Optional: IDs created in Appwrite Console (Database, Collection, Bucket).
# If not set, the app will show a setup message until you create them (see docs/appwrite-setup.md).
NEXT_PUBLIC_APPWRITE_DATABASE_ID=backing_score_db
NEXT_PUBLIC_APPWRITE_PROJECTS_COLLECTION_ID=projects
NEXT_PUBLIC_APPWRITE_UPLOADS_BUCKET_ID=uploads

